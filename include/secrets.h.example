#ifndef SECRETS_H
#define SECRETS_H

// Salin file ini menjadi secrets.h, lalu isi dengan kredensial kamu
#define FIREBASE_HOST   "URL_DATABASE_KAMU.firebaseio.com"
#define FIREBASE_AUTH   "DATABASE_SECRET_KAMU"
#define DEVICE_ID       "DEVICE_ID_KAMU"

// Konfigurasi Multi-WiFi
struct WiFiCredential {
  const char* ssid;
  const char* password;
};

const WiFiCredential WIFI_LIST[] = {
  {"WiFi_A", "password_a"},
  {"WiFi_B", "password_b"}
};

const int WIFI_COUNT = sizeof(WIFI_LIST) / sizeof(WIFI_LIST[0]);

#endif // SECRETS_H

